generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorType {
  country
  government
  military
  proxy_group
  region
  international_org
  economic_bloc
  strategic_asset
  non_state_actor
  unknown
}

enum RelationshipType {
  alliance
  hostility
  active_conflict
  ceasefire
  mediation
  economic_dependency
  military_support
  proxy_influence
  sanctions
  trade
  humanitarian_aid
  territorial_control
  diplomatic_pressure
  nuclear_pressure
  shipping_security
  unknown
}

enum RelationshipDirection {
  directed
  bidirectional
}

enum EventType {
  strike
  ceasefire_violation
  speech
  sanction
  aid_delivery
  hostage_release
  prisoner_release
  diplomatic_meeting
  missile_launch
  border_clash
  maritime_attack
  election
  treaty
  withdrawal
  mobilization
  unknown
}

enum SourceType {
  news_api
  rss
  official_statement
  dataset
  manual_note
  scraped_page
  pdf
  unknown
}

enum ClaimExtractor {
  human
  llm
  rule
}

enum ClaimStatus {
  draft
  approved
  rejected
  needs_review
}

model Actor {
  id               String           @id @default(cuid())
  canonicalName    String           @unique
  displayName      String
  actorType        ActorType
  parentActorId    String?
  countryCode      String?
  region           String?
  description      String?          @db.Text
  latitude         Float?
  longitude        Float?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  parentActor      Actor?           @relation("ActorHierarchy", fields: [parentActorId], references: [id])
  childActors      Actor[]          @relation("ActorHierarchy")
  aliases          ActorAlias[]
  sourceRelations  Relationship[]   @relation("RelationshipSource")
  targetRelations  Relationship[]   @relation("RelationshipTarget")
  metricSnapshots  MetricSnapshot[]
}

model ActorAlias {
  id        String  @id @default(cuid())
  actorId   String
  alias     String
  language  String?
  source    String?
  actor     Actor   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, alias])
}

model Relationship {
  id                String                 @id @default(cuid())
  sourceActorId     String
  targetActorId     String
  relationshipType  RelationshipType
  direction         RelationshipDirection  @default(directed)
  description       String?                @db.Text
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  sourceActor       Actor                  @relation("RelationshipSource", fields: [sourceActorId], references: [id], onDelete: Cascade)
  targetActor       Actor                  @relation("RelationshipTarget", fields: [targetActorId], references: [id], onDelete: Cascade)
  snapshots         RelationshipSnapshot[]
}

model RelationshipSnapshot {
  id               String        @id @default(cuid())
  relationshipId   String
  snapshotDate     DateTime
  strength         Int
  sentiment        Int
  confidence       Int
  volatility       Int
  sourceCount      Int           @default(0)
  visualColor      String
  visualThickness  Float
  isPrediction     Boolean       @default(false)
  modelRunId       String?
  notes            String?       @db.Text
  relationship     Relationship  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@index([relationshipId, snapshotDate])
}

model MetricSnapshot {
  id               String   @id @default(cuid())
  actorId          String
  snapshotDate     DateTime
  politicalPower   Int
  economicPower    Int
  militaryPower    Int
  diplomaticPower  Int
  softPower        Int
  instability      Int
  compositePower   Float
  confidence       Int
  sourceCount      Int      @default(0)
  actor            Actor    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, snapshotDate])
}

model Event {
  id                 String    @id @default(cuid())
  title              String
  eventDate          DateTime
  eventType          EventType @default(unknown)
  summary            String    @db.Text
  locationName       String?
  latitude           Float?
  longitude          Float?
  severity           Int
  confidence         Int
  sourceDocumentIds  String[]
  actorIds           String[]
  createdAt          DateTime  @default(now())
}

model SourceDocument {
  id                String      @id @default(cuid())
  sourceName        String
  sourceType        SourceType  @default(unknown)
  url               String?     @db.Text
  title             String
  author            String?
  publishedAt       DateTime?
  fetchedAt         DateTime    @default(now())
  language          String?
  rawText           String      @db.Text
  summary           String?     @db.Text
  reliabilityScore  Int
  hash              String      @unique
  claims            Claim[]
}

model Claim {
  id                     String          @id @default(cuid())
  sourceDocumentId       String
  claimText              String          @db.Text
  extractedBy            ClaimExtractor
  status                 ClaimStatus     @default(draft)
  actorIds               String[]
  relationshipId         String?
  eventId                String?
  proposedMetricChanges  Json?
  confidence             Int
  reviewerNotes          String?         @db.Text
  createdAt              DateTime        @default(now())
  reviewedAt             DateTime?
  sourceDocument         SourceDocument  @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
}