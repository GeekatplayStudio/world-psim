{
  "name": "balancesphere",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:local": "pnpm --parallel --filter @balancesphere/web --filter @balancesphere/api --filter @balancesphere/worker dev",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "eslint . --max-warnings=0 --ext .js,.mjs,.cjs,.ts,.tsx",
    "test": "vitest run",
    "typecheck": "pnpm run typecheck:shared && pnpm run typecheck:database && pnpm run typecheck:web && pnpm run typecheck:api && pnpm run typecheck:worker",
    "typecheck:shared": "tsc -p packages/shared/tsconfig.json --noEmit",
    "typecheck:database": "tsc -p packages/database/tsconfig.json --noEmit",
    "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
    "typecheck:api": "tsc -p apps/api/tsconfig.json --noEmit",
    "typecheck:worker": "tsc -p apps/worker/tsconfig.json --noEmit",
    "db:generate": "pnpm --filter @balancesphere/database prisma generate",
    "db:seed": "pnpm --filter @balancesphere/database seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}